{
  "manifest_version": 3,
  "name": "Roblox Site Tweaks",
  "description": "Various tweaks for the Roblox site like sidebar compacting.",
  "version": "1.1.0",
  "action": {
    "default_title": "Roblox sidebar settings",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.roblox.com/*",
    "https://roblox.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.roblox.com/*",
        "https://roblox.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}
